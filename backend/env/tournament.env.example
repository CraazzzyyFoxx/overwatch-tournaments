PORT=8004

# Challonge API credentials (HTTP Basic Auth).
# Required by tournament-service for the admin Challonge sync/import/export.
# Without these the service authenticates with empty credentials and Challonge
# responds 401 (surfaced as a `challonge_error`).
CHALLONGE_API_KEY=your_challonge_api_key
CHALLONGE_USERNAME=your_challonge_username
