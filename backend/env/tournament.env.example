PORT=8004

# Challonge API credentials (HTTP Basic Auth).
# Required by tournament-service for the admin Challonge sync/import/export.
# Without these the service authenticates with empty credentials and Challonge
# responds 401 (surfaced as a `challonge_error`).
# NOTE: the background worker (serve.py) also reads these — the auto-sync job no-ops
# (with a single warning) when they are missing, so set them for the worker process too.
CHALLONGE_API_KEY=your_challonge_api_key
CHALLONGE_USERNAME=your_challonge_username

# Background Challonge auto-sync (pull Challonge -> local) for active tournaments.
# Runs in the worker on an interval; set CHALLONGE_AUTO_SYNC_ENABLED=false to disable.
CHALLONGE_AUTO_SYNC_ENABLED=true
CHALLONGE_AUTO_SYNC_INTERVAL_MINUTES=5
