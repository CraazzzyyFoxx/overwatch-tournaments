# Gateway (Go) — Phase 0
#
# Shared vars come from the other env files and are NOT repeated here:
#   JWT_SECRET_KEY .................. auth.env (required; >= 32 chars)
#   REDIS_URL, POSTGRES_*, DB_PGBOUNCER, RABBITMQ_URL ... common.env
# The gateway reads those directly; this file carries gateway-specific
# settings plus the handful of shared vars it overrides. Every value below is
# the built-in default from internal/config/config.go — uncomment to change.

GATEWAY_PORT=8080

# Deployment environment. Falls back to SENTRY_ENVIRONMENT, then "development".
# "production" (case-insensitive) is fail-closed: RABBITMQ_URL becomes required
# and the admin docs page stays gated.
# GATEWAY_ENV=development

# Upstream HTTP services the gateway reverse-proxies to (docker-compose service
# names / ports). Everything else (auth, tournament, balancer, app) is reached
# over RPC via RABBITMQ_URL, not an UPSTREAM_* URL.
# In dev the Next.js frontend runs on the host (matches the dev compose default).
UPSTREAM_FRONTEND=http://host.docker.internal:3000
# UPSTREAM_PARSER=http://parser:8002
# UPSTREAM_ANALYTICS=http://analytics:8006

# WebSocket tuning (mirror realtime-service defaults).
WS_IDLE_TIMEOUT=60
WS_REPLAY_LIMIT=500

# Allowed WS Origins (CSV). The default covers the platform apex plus every
# tenant subdomain so ws.NewHandler never falls back to InsecureSkipVerify.
# An explicit (possibly empty) CSV overrides it — never leave production open.
# GATEWAY_WS_ALLOWED_ORIGINS=https://owt.craazzzyyfoxx.me,https://*.owt.craazzzyyfoxx.me

# Database. By default the gateway builds a libpq URL from the shared POSTGRES_*
# vars; set GATEWAY_DATABASE_URL to override the whole connection string.
# GATEWAY_DATABASE_URL=
#
# Gateway's own Postgres pool (ACL / event-replay / custom-domain reads; shares
# Postgres with the workers). Raise GATEWAY_DB_MAX_CONNS if WS/ACL load starves
# it. GATEWAY_DB_STATEMENT_TIMEOUT_MS is a server-side backstop cancelling any
# gateway query that runs longer (0 disables). It is applied ONLY on a direct
# Postgres connection — pgBouncer rejects statement_timeout as a startup
# parameter, so when DB_PGBOUNCER=true the gateway skips it; set the timeout on
# the Postgres role there instead (ALTER ROLE <user> SET statement_timeout).
GATEWAY_DB_MAX_CONNS=16
GATEWAY_DB_STATEMENT_TIMEOUT_MS=15000

# Rate limiting (in-memory token buckets, per-process; nginx limit_req is the
# coarse outer layer). A limit or window <= 0 disables that limiter.
#
# Auth endpoints anti-brute-force, keyed by client IP + path.
GATEWAY_AUTH_RATE_LIMIT=10
GATEWAY_AUTH_RATE_WINDOW=60
# Bounds ws.Handler's pre-handshake custom-domain Origin lookup per client IP
# (/ws carries no auth and no nginx limiter, so this is its only per-IP guard).
GATEWAY_WS_CUSTOM_DOMAIN_RATE_LIMIT=30
GATEWAY_WS_CUSTOM_DOMAIN_RATE_WINDOW=10
# Anonymous per-IP request throttle across all /api paths (no-bearer traffic
# only; authenticated Bearer requests bypass it). 0 = disabled (pass-through).
# Keep it generous — a single anonymous page view fans out into many public API
# calls, so a tight limit would throttle legitimate visitors. Over the limit
# the gateway replies 429. Windows are whole seconds.
GATEWAY_ANON_RATE_LIMIT=0
GATEWAY_ANON_RATE_WINDOW=10

# In-memory response cache TTL (seconds) for anonymous public tournament reads.
# Invalidation is event-driven; the TTL only bounds staleness for writes that
# emit no event and for missed pub/sub messages. 0 disables the cache entirely.
GATEWAY_RESPONSE_CACHE_TTL=30

# RPC bulkhead: max concurrent in-flight RPC calls per queue. Above the cap the
# gateway sheds requests with an immediate 503 instead of queueing them. 0 = off.
GATEWAY_RPC_MAX_INFLIGHT=64

# Prometheus usage metrics (top endpoints, active users, RPS/errors/latency)
# served on a dedicated internal port. Scraped by Prometheus over the app
# network as gateway:9110 — NOT published to the host / public edge.
GATEWAY_METRICS_PORT=9110

# Logging. LOG_LEVEL: debug|info|warn|error. LOG_FILE: rotating JSON log that
# Promtail tails into Loki (mounted at ./logs/gateway); empty = stdout only.
LOG_LEVEL=info
LOG_FILE=/logs/gateway.log

# Sentry (error monitoring + tracing + logs). An empty SENTRY_DSN disables the
# SDK entirely; the gateway then behaves exactly as before.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Release ties events to a version, e.g. gateway@<git-sha>. Optional.
SENTRY_RELEASE=
# Fraction of HTTP requests traced [0.0–1.0]; 0 disables tracing. Lower in prod.
SENTRY_TRACES_SAMPLE_RATE=0.2

# OpenTelemetry tracing (separate from Sentry; sampler is fixed to
# parentbased_traceidratio). Disabled by default.
TRACING_ENABLED=false
# OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_TRACES_SAMPLER_ARG=0.1

# Scalar API docs. The public page is on by default; the admin page (which
# enumerates every admin route) is fail-closed — only GATEWAY_DOCS_ADMIN=true
# enables it, otherwise /api/docs/admin returns 404.
GATEWAY_DOCS_ENABLED=true
GATEWAY_DOCS_ADMIN=false
# GATEWAY_DOCS_CDN=https://cdn.jsdelivr.net/npm/@scalar/api-reference@1.60.0
