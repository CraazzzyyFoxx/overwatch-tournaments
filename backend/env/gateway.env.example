# Gateway (Go) — Phase 0
#
# JWT_SECRET_KEY comes from auth.env (single source of truth).
# REDIS_URL, POSTGRES_*, DB_PGBOUNCER come from common.env.
# This file only carries gateway-specific settings.

GATEWAY_PORT=8080

# In dev the Next.js frontend runs on the host (matches the dev compose default).
UPSTREAM_FRONTEND=http://host.docker.internal:3000

# Upstream service URLs default to the docker-compose service names / ports.
# Uncomment to override.
# UPSTREAM_AUTH=http://auth:8001
# UPSTREAM_PARSER=http://parser:8002
# UPSTREAM_BALANCER=http://balancer:8003
# UPSTREAM_TOURNAMENT=http://tournament:8004
# UPSTREAM_ANALYTICS=http://analytics:8006
# UPSTREAM_APP=http://backend:8000

# WebSocket tuning (mirror realtime-service defaults).
WS_IDLE_TIMEOUT=60
WS_REPLAY_LIMIT=500
