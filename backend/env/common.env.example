ENVIRONMENT=development
PROJECT_URL=http://localhost
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://admin:secure_password@rabbitmq:5672
CORS_ORIGINS=["http://localhost", "http://localhost:3000"]

# Auth Service Configuration (for inter-service communication)
AUTH_SERVICE_URL=http://auth:8001
AUTH_SERVICE_TIMEOUT=5.0
AUTH_SERVICE_MAX_RETRIES=2

# Circuit Breaker Configuration
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30.0

# Observability Configuration
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
# Forward loguru logs to Sentry Logs (errors stay events, INFO stays breadcrumbs).
SENTRY_ENABLE_LOGS=true
SENTRY_LOGS_LEVEL=INFO
# Experimental Sentry trace-metrics (operational metrics still go to Prometheus).
SENTRY_ENABLE_METRICS=true
OTLP_ENDPOINT=http://otel-collector:4317
TRACING_ENABLED=true
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1
WORKER_METRICS_PORT=9100
JSON_LOGGING=true

POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=aqt_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true
DB_POOL_USE_LIFO=true
DB_CONNECT_TIMEOUT=10.0
DB_STATEMENT_TIMEOUT=30000
# Set true when connecting through pgBouncer in transaction pooling mode.
# Disables asyncpg prepared-statement caching, uses NullPool, and applies
# DB_STATEMENT_TIMEOUT per-transaction via SET LOCAL. Pool tuning above is
# ignored in this mode (pgBouncer owns the pool).
DB_PGBOUNCER=false

# S3 / MinIO Storage
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_ENDPOINT_URL=https://minio.example.com
S3_BUCKET_NAME=aqt
S3_PUBLIC_URL=https://minio.example.com/aqt
