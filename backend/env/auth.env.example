PORT=8001
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Service-to-service auth (client credentials)
# JSON examples:
# SERVICE_CLIENTS={"discord-service":"secret","parser-service":"secret"}
# SERVICE_SCOPES={"discord-service":["parser:logs"],"parser-service":[]}
SERVICE_CLIENTS={"discord-service":"your-discord-service-secret"}
SERVICE_SCOPES={"discord-service":["parser:logs"]}
SERVICE_ACCESS_TOKEN_EXPIRE_MINUTES=5
SERVICE_TOKEN_ISSUER=auth-service
SERVICE_TOKEN_AUDIENCE=internal

DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

BATTLENET_CLIENT_ID=your_battlenet_client_id
BATTLENET_CLIENT_SECRET=your_battlenet_client_secret
BATTLENET_REGION=eu

OAUTH_REDIRECT=https://owt.craazzzyyfoxx.me/auth/callback

OAUTH_STATE_EXPIRE_MINUTES=10
