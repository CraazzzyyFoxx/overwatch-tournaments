{
  "title": "Application Logs",
  "uid": "app-logs",
  "tags": ["logs", "loki"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(service)",
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "level",
        "label": "Level",
        "type": "custom",
        "query": "DEBUG,INFO,SUCCESS,WARNING,ERROR,CRITICAL",
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "query": "",
        "current": { "selected": false, "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Log Rate by Level",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (level) (rate({service=~\"$service\"}[1m]))",
          "legendFormat": "{{ level }}"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "WARNING" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "CRITICAL" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "INFO" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Log Volume by Service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": { "stacking": { "mode": "normal" }, "fillOpacity": 30 }
        }
      },
      "targets": [
        {
          "expr": "sum by (service) (rate({service=~\"$service\"}[5m]))",
          "legendFormat": "{{ service }}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error Rate by Service",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (rate({level=~\"ERROR|CRITICAL\", service=~\"$service\"}[1m]))",
          "legendFormat": "{{ service }}"
        }
      ]
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Errors by Service (selected range)",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["sum"] } },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 50 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({level=~\"ERROR|CRITICAL\", service=~\"$service\"}[$__range]))",
          "legendFormat": "{{ service }}",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Errors Only",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{service=~\"$service\", level=~\"ERROR|CRITICAL\"} |~ \"$search\"",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 3,
      "type": "logs",
      "title": "Live Log Stream",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "expr": "{service=~\"$service\", level=~\"$level\"} |~ \"$search\"",
          "legendFormat": ""
        }
      ]
    }
  ]
}
