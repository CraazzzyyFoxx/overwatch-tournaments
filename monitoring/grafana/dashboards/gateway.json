{
  "title": "Gateway",
  "uid": "gateway-usage",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "tags": ["gateway", "usage"],
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(gateway_http_requests_total[5m]))",
          "legendFormat": "total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP 5xx Error Ratio",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "expr": "gateway:http_error_ratio_5m",
          "legendFormat": "5xx ratio",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(gateway_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(gateway_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(gateway_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "title": "WebSocket Connections",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "gateway_ws_connections{state=\"total\"}",
          "legendFormat": "total",
          "refId": "A"
        },
        {
          "expr": "gateway_ws_connections{state=\"authenticated\"}",
          "legendFormat": "authenticated",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active Users",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "gateway_active_users{window=\"1d\"}",
          "legendFormat": "DAU",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "gateway_active_users{window=\"7d\"}",
          "legendFormat": "WAU",
          "refId": "B",
          "instant": true
        },
        {
          "expr": "gateway_active_users{window=\"30d\"}",
          "legendFormat": "MAU",
          "refId": "C",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "title": "Active Users Over Time",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 16, "w": 16, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "gateway_active_users",
          "legendFormat": "{{ window }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Top Endpoints by Request Rate",
      "type": "table",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(15, sum by (route) (rate(gateway_http_requests_total[5m])))",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "renameByName": { "route": "Endpoint", "Value": "req/s" }
          }
        }
      ]
    }
  ]
}
