{
  "title": "Platform Overview",
  "uid": "platform-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "tags": ["platform", "overview", "observability"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "HTTP Error Ratio",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "(100 * sum(rate(http_requests_total{job=~\"app-service|auth-service|parser-service|balancer-service\",status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=~\"app-service|auth-service|parser-service|balancer-service\"}[5m])), 0.001)) or vector(0)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2 } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "HTTP p95 Latency",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "max(histogram_quantile(0.95, sum by (job, le) (rate(http_request_duration_seconds_bucket{job=~\"app-service|auth-service|parser-service|balancer-service\"}[5m]))))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Worker Failures / min",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(worker_messages_processed_total{status=\"error\"}[1m])) or vector(0)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 2 } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Redis Hit Ratio",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "(100 * sum(rate(redis_keyspace_hits_total[5m])) / clamp_min(sum(rate(redis_keyspace_hits_total[5m])) + sum(rate(redis_keyspace_misses_total[5m])), 0.001)) or vector(0)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2 } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by (job) (rate(http_requests_total{job=~\"app-service|auth-service|parser-service|balancer-service\"}[5m]))", "legendFormat": "{{ job }}" }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Queue Depth",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by (queue) (rabbitmq_queue_messages{queue!~\".*\\\\.dlq\"})", "legendFormat": "{{ queue }}" }]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Worker Inflight Messages",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by (job, queue) (worker_inflight_messages)", "legendFormat": "{{ job }} / {{ queue }}" }]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Redis Memory / Ops",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "redis_memory_used_bytes", "legendFormat": "memory_used" },
        { "expr": "rate(redis_commands_processed_total[1m])", "legendFormat": "ops_per_sec" }
      ]
    }
  ]
}
