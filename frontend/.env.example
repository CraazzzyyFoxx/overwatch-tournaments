# Frontend (Next.js)
# Copy to .env (or .env.local) and restart `npm run dev`.

# Site display name (title, footer, etc.)
NEXT_PUBLIC_SITE_NAME="Moonrise Tournaments"

# Public base URL for the frontend (used in metadata like Open Graph).
# Must be an absolute URL including protocol, e.g. "https://example.com".
NEXT_PUBLIC_SITE_URL="https://aqt.craazzzyyfoxx.me"

# Main icon / logo path (must exist under `frontend/public`).
NEXT_PUBLIC_SITE_ICON="/logo.webp"

# Browser favicon path (must exist under `frontend/public`).
NEXT_PUBLIC_SITE_FAVICON="/favicon.ico"

# Default fetch cache policy for /api/v1 reads: unset (HTTP default),
# "no-cache", or "network-only" (no-store).
# NEXT_PUBLIC_CACHE_POLICY=

# Everything is one gateway behind one origin. The browser uses relative,
# same-origin paths (/api/v1, /api/balancer, /api/analytics, /api/auth,
# /api/realtime/ws) — no per-service base URLs are needed.
#
# Only server-side fetches (SSR + route handlers + middleware) need an absolute
# base: the internal gateway. In Docker compose this is the gateway service
# (http://gateway:8080, set there). For a host-run `next dev`, point it at the
# gateway's published port:
NEXT_INTERNAL_API_URL=http://localhost:8080
